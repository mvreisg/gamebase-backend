{
    "name": "mvreisg/gamebase-backend",
    "description": "A simple PHP API for game database.",
    "type": "project",
    "autoload": {
        "psr-4": {
            "Mvreisg\\GamebaseBackend\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Marcus Vinicius",
            "email": "marcus_viniciusreis@hotmail.com"
        }
    ],
    "require": {
        "vlucas/phpdotenv": "^5.6",
        "robmorgan/phinx": "^0.16.6"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.68",
        "squizlabs/php_codesniffer": "^3.0" 
    },
    "scripts": {
	    "format": "vendor/bin/php-cs-fixer fix",        
        "lint": "vendor/bin/phpcs --standard=psr12 ./src ./public",
        "lint:fix": "vendor/bin/phpcbf --standard=psr12 ./src ./public",
        "phinx": "vendor/bin/phinx"
    }
}
