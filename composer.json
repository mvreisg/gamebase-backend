{
    "name": "mvreisg/gamebase-backend",
    "description": "A simple PHP API for game database.",
    "type": "project",
    "autoload": {
        "psr-4": {
            "Mvreisg\\GamebaseBackend\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mvreisg\\GamebaseBackend\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Marcus Vinicius",
            "email": "marcus_viniciusreis@hotmail.com"
        }
    ],
    "require": {
        "vlucas/phpdotenv": "^5.6",
        "robmorgan/phinx": "^0.16.6",
        "firebase/php-jwt": "^6.11",
        "predis/predis": "^2.3",
        "defuse/php-encryption": "^2.4"
    },
    "require-dev": {        
        "squizlabs/php_codesniffer": "^3.0",
        "phpunit/phpunit": "^11.5",
        "friendsofphp/php-cs-fixer": "^3.75" 
    },
    "scripts": {
        "lint": "vendor/bin/php-cs-fixer list-files",
        "lint:fix": "vendor/bin/php-cs-fixer fix .",
        "format": "vendor/bin/phpcs --ignore=*/vendor/*,*/db/*,*/scripts/* --standard=psr12 ./",
        "format:fix": "vendor/bin/phpcbf --ignore=*/vendor/*,*/db/*,*/scripts/* --standard=psr12 ./",
        "phinx": "vendor/bin/phinx",
        "phpunit:test": "vendor/bin/phpunit ./tests --testdox"
    }
}
