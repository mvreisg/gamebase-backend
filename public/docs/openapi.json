{
    "openapi": "3.0.0",
    "info": {
        "title": "Gamebase-Backend API",
        "description": "API documentation for the Gamebase-Backend project.",
        "version": "1.0.0"
    },
    "paths": {
        "/authentication/validate": {
            "get": {
                "tags": [
                    "Authentication"
                ],
                "summary": "Validate",
                "description": "Validates the provided authentication token and returns the associated authentication data if valid.",
                "operationId": "8ab48900be2528fbbabdbfd68311dff1",
                "responses": {
                    "200": {
                        "description": "Valid token",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "valid"
                                        },
                                        "data": {
                                            "$ref": "#/components/schemas/AuthenticationData"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    }
                ]
            }
        },
        "/session/login": {
            "post": {
                "tags": [
                    "Session"
                ],
                "summary": "Login",
                "description": "Receives the user credentials and if valid, creates a session and returns the authentication token",
                "operationId": "3619399df8e097ceb8f81784de3cc45b",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "username": {
                                        "type": "string",
                                        "example": "mvreisg"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "mg4ing854g48n"
                                    },
                                    "one_week_login": {
                                        "type": "boolean",
                                        "example": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Response if credentials is valid",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "properties": {
                                                "expires": {
                                                    "properties": {
                                                        "unit": {
                                                            "type": "string",
                                                            "example": "seconds"
                                                        },
                                                        "time": {
                                                            "type": "integer",
                                                            "example": 604800
                                                        }
                                                    },
                                                    "type": "object"
                                                },
                                                "token": {
                                                    "type": "string",
                                                    "example": "Bearer gmeroibmerong98345nh04h45"
                                                },
                                                "user": {
                                                    "properties": {
                                                        "id": {
                                                            "type": "integer",
                                                            "example": 1
                                                        },
                                                        "username": {
                                                            "type": "string",
                                                            "example": "mvreisg"
                                                        },
                                                        "permissions": {
                                                            "type": "array",
                                                            "items": {
                                                                "$ref": "#/components/schemas/UserSectorPermissionEntity"
                                                            }
                                                        }
                                                    },
                                                    "type": "object"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Response if a body value is missing, if the user does not exist",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "oneOf": [
                                        {
                                            "title": "Missing keys",
                                            "properties": {
                                                "message": {
                                                    "type": "string",
                                                    "example": "Missing body keys: "
                                                },
                                                "body": {
                                                    "type": "array",
                                                    "items": {
                                                        "type": "string"
                                                    },
                                                    "example": [
                                                        "username, password"
                                                    ]
                                                }
                                            },
                                            "type": "object"
                                        },
                                        {
                                            "title": "User not found",
                                            "properties": {
                                                "message": {
                                                    "type": "string"
                                                }
                                            },
                                            "type": "object"
                                        }
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "AuthenticationData": {
                "properties": {
                    "userId": {
                        "type": "integer",
                        "example": 1
                    },
                    "username": {
                        "type": "string",
                        "example": "john_doe"
                    }
                },
                "type": "object"
            },
            "PermissionEntity": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "create"
                    },
                    "value": {
                        "type": "string",
                        "example": "create"
                    },
                    "is_active": {
                        "type": "boolean",
                        "example": true
                    }
                },
                "type": "object"
            },
            "SectorEntity": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "name": {
                        "type": "string",
                        "example": "game"
                    },
                    "value": {
                        "type": "string",
                        "example": "game"
                    },
                    "is_active": {
                        "type": "boolean",
                        "example": true
                    }
                },
                "type": "object"
            },
            "UserEntity": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "username": {
                        "type": "string",
                        "example": "mvreisg"
                    },
                    "password": {
                        "type": "string",
                        "example": "f03jg9j043g"
                    },
                    "is_active": {
                        "type": "boolean",
                        "example": true
                    }
                },
                "type": "object"
            },
            "UserSectorPermissionEntity": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 1
                    },
                    "user": {
                        "$ref": "#/components/schemas/UserEntity"
                    },
                    "sector": {
                        "$ref": "#/components/schemas/SectorEntity"
                    },
                    "permission": {
                        "$ref": "#/components/schemas/PermissionEntity"
                    }
                },
                "type": "object"
            }
        },
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "bearerFormat": "JWT",
                "scheme": "bearer"
            }
        }
    },
    "tags": [
        {
            "name": "Authentication",
            "description": "Endpoints related to authentication"
        },
        {
            "name": "Session",
            "description": "Endpoints related to session management"
        }
    ]
}